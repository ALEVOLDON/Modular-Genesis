---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { tracks } from "../data/tracks";

const lessons = await getCollection("lessons");

const grouped = tracks.map((track) => ({
  ...track,
  lessons: lessons
    .filter((lesson) => lesson.data.track === track.key)
    .sort((a, b) => a.data.order - b.data.order)
}));
---

<BaseLayout title="Course | Modular Genesis" description="Course outline for Modular Genesis.">
  <section class="hero">
    <div class="eyebrow">Course Outline</div>
    <div class="hero-copy">
      <h1>A documentation-first course scaffold.</h1>
      <p>
        The course is not yet written lesson-by-lesson, but the structure is now stable enough
        to start adding Markdown lessons, patch references, and diagrams in parallel.
      </p>
      <div class="track-nav">
        {grouped.map((track) => (
          <a class="track-chip" href={`#${track.key}`}>{track.title}</a>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="cards-3">
      {tracks.map((section) => (
        <article class="card">
          <span class="card-kicker">Track</span>
          <h3>{section.title}</h3>
          <p>{section.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="panel">
      <h2>Published lessons</h2>
      <ul class="flow-list">
        {grouped.map((track) => (
          <li>
            <strong>{track.title}:</strong> {track.lessons.length} lesson(s) available.
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section>
    <div class="cards-2">
      {grouped
        .filter((track) => track.lessons.length > 0)
        .map((track) => (
          <article class="card" id={track.key}>
            <span class="card-kicker">{track.title}</span>
            <h3>{track.lessons.length} lesson(s)</h3>
            <ul class="bullet-list">
              {track.lessons.map((lesson) => (
                <li>
                  <a href={`/course/${lesson.slug}/`}>{lesson.data.title}</a>
                </li>
              ))}
            </ul>
          </article>
        ))}
    </div>
  </section>

  <section>
    <div class="panel">
      <h2>Lesson format</h2>
      <ul class="flow-list">
        <li><strong>Theory:</strong> concise explanation of the concept.</li>
        <li><strong>Patch idea:</strong> simple routing model or signal chain.</li>
        <li><strong>Practice:</strong> one concrete task to rebuild or extend the system.</li>
      </ul>
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <h2>Lesson anatomy</h2>
        <p>A cleaned-up version of the strongest lesson structure idea from the earlier presentation material.</p>
      </div>
    </div>
    <div class="media-frame">
      <img src="/diagrams/lesson-anatomy.svg" alt="Lesson anatomy diagram showing theory, patch diagram, patch file, and practice task." />
    </div>
  </section>
</BaseLayout>
