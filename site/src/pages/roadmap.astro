---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { tracks } from "../data/tracks";
import { withBase } from "../lib/paths";

const lessons = await getCollection("lessons");
const patches = await getCollection("patches");
const notes = await getCollection("notes");

const trackTones = ["#66f7ff", "#7cf0c9", "#ff5fcb", "#ffe45c", "#66d9ff"];

const roadmapStages = tracks.map((track, index) => ({
  ...track,
  index,
  tone: trackTones[index % trackTones.length],
  lessonCount: lessons.filter((lesson) => lesson.data.track === track.key).length,
  patchCount: patches.filter((patch) => patch.data.track === track.key || (track.key === "hybrid" && patch.data.track === "performances")).length
}));
---

<BaseLayout title="Roadmap | Modular Genesis" description="Learning roadmap for Modular Genesis.">
  <div class="page-stack">
    <section class="band band-hero">
      <div class="band-shell">
        <div class="display-grid">
          <div>
            <div class="eyebrow">System Evolution Protocol</div>
            <h1 class="display-title" style="max-width: 8ch; font-size: clamp(3.2rem, 8vw, 6rem);">
              Modular <span class="accent">Genesis</span> roadmap from first signal flow to audiovisual systems.
            </h1>
            <p class="lede">
              This page turns the planning notes into a staged public blueprint. Each track is treated as a
              formal phase with its own concepts, lessons, and patch direction.
            </p>
            <div class="actions">
              <a class="button" href={withBase("/course")}>Open lessons</a>
              <a class="button-secondary" href={withBase("/resources")}>Read reference notes</a>
            </div>
          </div>

          <div class="hero-dashboard">
            <article class="feature-card">
              <span class="section-label">Current roadmap status</span>
              <h3>Five stages, one connected system.</h3>
              <ul class="metric-list">
                <li>
                  <strong>{roadmapStages.length}</strong>
                  stage clusters already defined
                </li>
                <li>
                  <strong>{lessons.length}</strong>
                  lessons already connected to those stages
                </li>
                <li>
                  <strong>{notes.length}</strong>
                  conceptual notes supporting the sequence
                </li>
              </ul>
            </article>

            <div class="hero-dashboard-grid">
              {roadmapStages.slice(0, 4).map((stage) => (
                <article class="mini-card">
                  <span class="mini-stat" style={`color:${stage.tone};`}>0{stage.index + 1}</span>
                  <h4>{stage.title}</h4>
                  <p>{stage.roadmapTopics[0]}</p>
                </article>
              ))}
            </div>

            <article class="feature-card">
              <span class="section-label">Operational view</span>
              <h3>How the roadmap behaves in practice</h3>
              <ul class="feature-list">
                <li><strong>Lessons:</strong> each stage can expand into a focused lesson cluster.</li>
                <li><strong>Patches:</strong> stage logic maps directly into patch entries and future `.vcv` files.</li>
                <li><strong>Docs:</strong> notes and diagrams clarify system transitions between stages.</li>
              </ul>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="band band-deep">
      <div class="band-shell">
        <div class="section-copy">
          <span class="section-label">Roadmap Timeline</span>
          <h2>Each stage shifts the system from isolated modules toward a full performance organism.</h2>
          <p>
            The progression is not just pedagogical. It also mirrors how the repository, patch library, and site
            can evolve in parallel without collapsing into disconnected pieces.
          </p>
        </div>

        <div class="timeline" style="margin-top: 34px;">
          {roadmapStages.map((stage) => (
            <Fragment>
              {stage.index % 2 === 0 ? (
                <article class="timeline-card left" style={`--track-tone:${stage.tone};`}>
                  <span class="timeline-topline">Stage {stage.index + 1}</span>
                  <h3>{stage.title}</h3>
                  <p>{stage.description}</p>
                  <ul class="timeline-list">
                    {stage.roadmapTopics.map((topic) => (
                      <li>{topic}</li>
                    ))}
                  </ul>
                </article>
              ) : (
                <div></div>
              )}

              <div class="timeline-marker" style={`--track-tone:${stage.tone};`}>
                <div class="timeline-node">{stage.index + 1}</div>
              </div>

              {stage.index % 2 === 1 ? (
                <article class="timeline-card right" style={`--track-tone:${stage.tone};`}>
                  <span class="timeline-topline">Stage {stage.index + 1}</span>
                  <h3>{stage.title}</h3>
                  <p>{stage.description}</p>
                  <ul class="timeline-list">
                    {stage.roadmapTopics.map((topic) => (
                      <li>{topic}</li>
                    ))}
                  </ul>
                </article>
              ) : (
                <div></div>
              )}
            </Fragment>
          ))}
        </div>
      </div>
    </section>

    <section class="band band-alt">
      <div class="band-shell">
        <div class="timeline-summary">
          <div class="feature-card">
            <span class="section-label">System diagrams</span>
            <h2>Two diagrams anchor the roadmap visually.</h2>
            <p>
              These diagrams replace the earlier slide language with site-native visuals. They clarify both the
              routing logic and the broader ecosystem around the project.
            </p>
            <div class="actions">
              <a class="button-secondary" href={withBase("/resources")}>Open resources</a>
            </div>
          </div>

          <div class="content-column">
            <div class="media-frame">
              <img src={withBase("/diagrams/hybrid-routing.svg")} alt="Hybrid routing diagram for Ableton, VCV Rack, recording, and visuals." />
            </div>
            <div class="media-frame">
              <img src={withBase("/diagrams/tool-ecosystem.svg")} alt="Tool ecosystem diagram showing VCV Rack, Ableton Live, routing, and visual layer." />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="band band-subtle">
      <div class="band-shell">
        <div class="section-head">
          <div class="section-copy">
            <span class="section-label">Stage status</span>
            <h2>Each phase already has a clear relationship to lessons and patches.</h2>
            <p>This makes the roadmap actionable instead of decorative: every stage can now be expanded into real material.</p>
          </div>
          <a class="button-secondary" href={withBase("/patches")}>Open patch library</a>
        </div>

        <div class="status-grid">
          {roadmapStages.map((stage) => (
            <article class="status-pill">
              <strong>{stage.lessonCount}</strong>
              {stage.title}: lessons published
            </article>
          ))}
        </div>

        <div class="stack-grid" style="margin-top: 18px;">
          {roadmapStages.slice(0, 3).map((stage) => (
            <article class="feature-card" style={`--track-tone:${stage.tone};`}>
              <span class="timeline-topline">Patch direction</span>
              <h3>{stage.title}</h3>
              <p>{stage.patchCount} patch entries currently mapped to this stage or its adjacent performance layer.</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
