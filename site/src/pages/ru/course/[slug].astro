---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { tracks, trackLabelMap } from "../../../data/tracks";
import { withBase } from "../../../lib/paths";

export async function getStaticPaths() {
  const lessons = await getCollection("ru-lessons");

  return lessons.map((lesson) => ({
    params: { slug: lesson.slug },
    props: { lesson }
  }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);
const trackCopyMap = {
  foundations: {
    title: "Foundations",
    description: "Старт с signal flow, базовой модуляции и первых sound design patches.",
    topics: ["CV и audio", "oscillator, filter, VCA", "envelopes и LFOs"]
  },
  sequencing: {
    title: "Sequencing",
    description: "Переход от статичного звука к clocked motion, ритму и tonal control.",
    topics: ["clock, trigger, gate", "sequencers и quantizers", "melodic и rhythmic motion"]
  },
  generative: {
    title: "Generative",
    description: "Системы, которые меняются во времени за счет probability, mutation и feedback.",
    topics: ["sample and hold", "Turing-style mutation", "feedback и slow modulation"]
  },
  hybrid: {
    title: "Hybrid",
    description: "Связка VCV Rack и Ableton Live для routing, записи и arrangement.",
    topics: ["VCV Rack + Ableton", "virtual audio routing", "multichannel recording"]
  },
  audiovisual: {
    title: "Audiovisual",
    description: "Преобразование поведения звука в visuals и performance-oriented output.",
    topics: ["OSC и MIDI visual control", "audio-reactive graphics", "Blender / Three.js / TouchDesigner"]
  }
};

const translatedTrack = trackCopyMap[lesson.data.track as keyof typeof trackCopyMap] || trackCopyMap.foundations;

const relatedPatches = (await getCollection("ru-patches"))
  .filter((patch) => patch.data.track === lesson.data.track)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const siblingLessons = (await getCollection("ru-lessons"))
  .filter((entry) => entry.data.track === lesson.data.track && entry.slug !== lesson.slug)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const allLessons = await getCollection("ru-lessons");
const sortedLessons = allLessons.sort((a, b) => {
  const trackIndexA = tracks.findIndex(t => t.key === a.data.track);
  const trackIndexB = tracks.findIndex(t => t.key === b.data.track);
  if (trackIndexA !== trackIndexB) return trackIndexA - trackIndexB;
  return a.data.order - b.data.order;
});

const currentIndex = sortedLessons.findIndex(l => l.slug === lesson.slug);
const prevLesson = currentIndex > 0 ? sortedLessons[currentIndex - 1] : null;
const nextLesson = currentIndex < sortedLessons.length - 1 ? sortedLessons[currentIndex + 1] : null;
---

<BaseLayout
  title={`${lesson.data.title} | Modular Genesis | RU`}
  description={lesson.data.summary}
  lang="ru"
  navItems={[
    { href: "/ru/", label: "Главная" },
    { href: "/ru/roadmap", label: "План" },
    { href: "/ru/course", label: "Курс" },
    { href: "/ru/resources", label: "Материалы" }
  ]}
  localeSwitch={{ href: `/course/${lesson.slug}/`, label: "EN" }}
>
  <div class="page-stack">
    <section class="band band-hero">
      <div class="band-shell">
        <div class="display-grid">
          <div>
            <div class="eyebrow">{translatedTrack.title}</div>
            <h1 class="display-title" style="max-width: 8ch; font-size: clamp(3.1rem, 7vw, 5.6rem);">
              {lesson.data.title}
            </h1>
            <p class="lede">{lesson.data.summary}</p>
            <div class="actions">
              <a class="button" href={withBase("/ru/course")}>Назад к курсу</a>
              <a class="button-secondary" href={withBase("/ru/roadmap")}>Открыть roadmap</a>
            </div>
          </div>

          <div class="hero-dashboard">
            <article class="feature-card">
              <span class="section-label">Контекст трека</span>
              <h3>{translatedTrack.title}</h3>
              <p>{translatedTrack.description}</p>
              <ul class="feature-list">
                {translatedTrack.topics.slice(0, 3).map((topic) => (
                  <li>{topic}</li>
                ))}
              </ul>
            </article>

            <div class="hero-dashboard-grid">
              <article class="mini-card">
                <span class="mini-stat">Урок</span>
                <h4>Содержательный слой</h4>
                <p>Теория, структура и практический контекст собираются из content-файлов и остаются связанными.</p>
              </article>
              <article class="mini-card">
                <span class="mini-stat">{relatedPatches.length}</span>
                <h4>Связанные патчи</h4>
                <p>Для этого трека уже есть конкретные repository anchors и точки привязки в библиотеке.</p>
              </article>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="band band-subtle">
      <div class="band-shell">
        <article class="feature-card prose-panel">
          <Content />
          
          <div class="lesson-navigation">
            {prevLesson ? (
              <a href={withBase(`/ru/course/${prevLesson.slug}/`)} class="button-secondary lesson-nav-link prev">
                <span class="lesson-nav-label">← Предыдущий урок</span>
                <span>{prevLesson.data.title}</span>
              </a>
            ) : <div />}
            
            {nextLesson ? (
              <a href={withBase(`/ru/course/${nextLesson.slug}/`)} class="button lesson-nav-link next">
                <span class="lesson-nav-label">Следующий урок →</span>
                <span>{nextLesson.data.title}</span>
              </a>
            ) : <div />}
          </div>
        </article>
      </div>
    </section>

    <section class="band band-deep">
      <div class="band-shell">
        <div class="stack-grid">
          <article class="feature-card">
            <span class="card-kicker">Связанные патчи</span>
            <h3>Опорные патч-материалы</h3>
            <p>Используй эти patch entries как репозиторные якоря для текущего трека и его практических шагов.</p>
            <ul class="feature-list">
              {relatedPatches.map((patch) => (
                <li>
                  <a href={withBase(`/ru/patches/${patch.slug}/`)}>{patch.data.title}</a>
                </li>
              ))}
            </ul>
          </article>

          <article class="feature-card">
            <span class="card-kicker">Тот же трек</span>
            <h3>Продолжить внутри {translatedTrack.title}</h3>
            <p>Соседние уроки внутри того же трека удерживают развитие связным и не дают материалу распасться.</p>
            <ul class="feature-list">
              {siblingLessons.map((entry) => (
                <li>
                  <a href={withBase(`/ru/course/${entry.slug}/`)}>{entry.data.title}</a>
                </li>
              ))}
            </ul>
          </article>

          <article class="feature-card">
            <span class="card-kicker">Связанная диаграмма</span>
            <h3>Обзор гибридной маршрутизации</h3>
            <p>Эта системная диаграмма связывает модульный движок, DAW и визуальный вывод в одну читаемую схему.</p>
            <div class="actions">
              <a class="button-secondary" href={withBase("/ru/roadmap")}>Открыть roadmap</a>
              <a class="button-secondary" href={withBase("/ru/patches")}>Открыть библиотеку патчей</a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
