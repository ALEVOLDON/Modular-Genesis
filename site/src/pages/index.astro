---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { tracks } from "../data/tracks";
import { withBase } from "../lib/paths";

const lessons = (await getCollection("lessons")).sort((a, b) => {
  if (a.data.track === b.data.track) return a.data.order - b.data.order;
  return a.data.track.localeCompare(b.data.track);
});

const notes = (await getCollection("notes")).sort((a, b) => a.data.order - b.data.order);
const patches = (await getCollection("patches")).sort((a, b) => a.data.order - b.data.order);

const featuredLessons = lessons.slice(0, 3);
const featuredNotes = notes.slice(0, 3);
const featuredPatches = patches.slice(0, 3);

const heroSignals = [
  "Open roadmap and course skeleton",
  "Patch library ready for real artifacts",
  "English and Russian entry points online"
];

const pillars = [
  {
    kicker: "System",
    title: "Hybrid audio architecture",
    text: "Ableton Live, VCV Rack, routing, recording, and visuals are treated as one connected system.",
    points: ["modular engine + DAW layer", "routing as composition", "visual output as extension"]
  },
  {
    kicker: "Course",
    title: "Structured learning path",
    text: "The project already has tracks, lessons, notes, and internal logic instead of loose tutorial fragments.",
    points: ["foundations to audiovisual", "lesson + note + patch model", "roadmap-led curriculum"]
  },
  {
    kicker: "Library",
    title: "Patch-first repository design",
    text: "Patch entries, repository folders, and future real `.vcv` files already have a stable home.",
    points: ["public repo structure", "patch references on pages", "ready for real artifacts"]
  }
];

const toolCards = [
  {
    title: "VCV Rack",
    text: "Core modular environment for synthesis, sequencing, probability, and signal design."
  },
  {
    title: "Ableton Live",
    text: "Arrangement, routing, recording, performance control, and hybrid workflow anchor."
  },
  {
    title: "Visual Layer",
    text: "Three.js, Blender, and future real-time visual systems connected to sound behavior."
  },
  {
    title: "Repository",
    text: "Documentation, patches, diagrams, and lessons built as one public knowledge system."
  }
];
---

<BaseLayout
  title="Modular Genesis"
  description="Open modular synthesis, generative music, and audiovisual systems."
  localeSwitch={{ href: "/ru/", label: "RU" }}
>
  <div class="page-stack">
    <section class="band band-hero">
      <div class="band-shell">
        <div class="display-grid">
          <div>
            <div class="eyebrow">Public Draft v0.1</div>
            <h1 class="display-title">
              Build the <span class="accent">generative</span> bridge between modular sound and visual systems.
            </h1>
            <p class="lede">
              Modular Genesis is an open documentation-first project around `VCV Rack`, `Ableton Live`,
              generative patch design, hybrid routing, and audiovisual structure. The goal is not to
              publish scattered tutorials, but to build a coherent public system.
            </p>
            <div class="actions">
              <a class="button" href={withBase("/roadmap")}>Open roadmap</a>
              <a class="button-secondary" href={withBase("/course")}>Browse lessons</a>
              <a class="button-secondary" href={withBase("/resources")}>Read notes</a>
            </div>
            <div class="track-nav">
              {heroSignals.map((signal) => (
                <span class="track-chip">{signal}</span>
              ))}
            </div>
          </div>

          <div class="hero-dashboard">
            <article class="feature-card">
              <span class="section-label">Core pipeline</span>
              <h3>From control logic to performance output</h3>
              <p>
                The site, lessons, notes, and patch entries already orbit one production backbone:
                controller input, modular generation, audio capture, and future visual synthesis.
              </p>
              <div class="media-frame" style="margin: 18px 0;">
                <img src={withBase("/images/hero_modular_cables.png")} alt="Macro shot of modular patch cables and glowing interface" />
              </div>
              <div class="code-block" style="margin-top: 0;">Ableton / MIDI
  ->
VCV Rack
  ->
Generative Patch
  ->
Audio Engine
  ->
Visual Engine
  ->
Performance</div>
            </article>

            <div class="hero-dashboard-grid">
              <article class="mini-card">
                <span class="mini-stat">{tracks.length}</span>
                <h4>Structured tracks</h4>
                <p>Foundations, sequencing, generative, hybrid, and audiovisual are already defined.</p>
              </article>
              <article class="mini-card">
                <span class="mini-stat">{lessons.length}</span>
                <h4>Published lessons</h4>
                <p>The course already contains real pages instead of a placeholder syllabus.</p>
              </article>
              <article class="mini-card">
                <span class="mini-stat">{notes.length}</span>
                <h4>Reference notes</h4>
                <p>System-level notes explain routing, patch logic, and project direction.</p>
              </article>
              <article class="mini-card">
                <span class="mini-stat">{patches.length}</span>
                <h4>Patch entries</h4>
                <p>The repository is prepared for real `.vcv` artifacts without changing site structure.</p>
              </article>
            </div>

            <article class="feature-card">
              <span class="section-label">Current focus</span>
              <h3>What exists now</h3>
              <ul class="feature-list">
                <li><strong>Roadmap:</strong> staged structure from signal flow to audiovisual systems.</li>
                <li><strong>Course:</strong> lessons already grouped by track and route.</li>
                <li><strong>Resources:</strong> concept notes and system diagrams published on-site.</li>
              </ul>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="band band-deep">
      <div class="band-shell">
        <div class="section-copy">
          <span class="section-label">Ecosystem</span>
          <h2>The tools are separated by role, but designed as one organism.</h2>
          <p>
            Instead of treating synthesis, arrangement, and visuals as isolated disciplines, the project
            treats them as linked layers of the same system.
          </p>
        </div>
        <div class="stack-grid-4" style="margin-top: 26px;">
          {toolCards.map((tool) => (
            <article class="feature-card">
              <span class="card-kicker">Tool</span>
              <h3>{tool.title}</h3>
              <p>{tool.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="band band-alt">
      <div class="band-shell">
        <div class="split-hero">
          <div class="feature-card">
            <span class="section-label">Why Modular</span>
            <h2>Not just a sound design workflow, but a framework for discovery.</h2>
            <p>
              Modular systems create a rare overlap between composition, logic, improvisation, and
              engineering. That makes them ideal for building living systems instead of static presets.
            </p>
            <ul class="feature-list">
              <li><strong>Routing as composition:</strong> the signal path becomes part of the musical form.</li>
              <li><strong>Generative logic:</strong> clocks, probability, mutation, and feedback create evolving behavior.</li>
              <li><strong>Audiovisual expansion:</strong> sound events can later control geometry, motion, and scenes.</li>
            </ul>
          </div>

          <div class="media-frame">
            <img src={withBase("/images/generative_abstract_mesh.png")} alt="Abstract generative mesh representing audiovisual data" />
          </div>
        </div>
      </div>
    </section>

    <section class="band band-subtle">
      <div class="band-shell">
        <div class="section-copy">
          <span class="section-label">Architecture</span>
          <h2>Three durable outputs are already in place.</h2>
          <p>
            The current public version is not finished content. It is a stable project skeleton:
            system architecture, learning architecture, and repository architecture.
          </p>
        </div>
        <div class="timeline-summary" style="margin-top: 26px;">
          <article class="feature-card">
            <span class="card-kicker">Blueprint</span>
            <h3>The site is already split into stable layers.</h3>
            <p>
              The current version is strongest when read as infrastructure: one layer explains the system,
              one layer teaches the workflow, and one layer stores the patch library that future real artifacts will use.
            </p>
            <ul class="feature-list">
              <li><strong>System layer:</strong> diagrams, notes, and roadmap define the structure.</li>
              <li><strong>Learning layer:</strong> lessons are grouped by track, not published as disconnected pages.</li>
              <li><strong>Repository layer:</strong> patch entries already map to folders and future media artifacts.</li>
            </ul>
          </article>

          <div class="card-stack">
            {pillars.map((pillar) => (
              <article class="card">
                <span class="card-kicker">{pillar.kicker}</span>
                <h3>{pillar.title}</h3>
                <p>{pillar.text}</p>
                <ul class="feature-list">
                  {pillar.points.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="band band-deep">
      <div class="band-shell">
        <div class="section-head">
          <div class="section-copy">
            <span class="section-label">Live Content</span>
            <h2>The site already has usable material, not just placeholders.</h2>
            <p>Tracks define the sequence first, then lessons, notes, and patches fill each layer with public material.</p>
          </div>
          <a class="button-secondary" href={withBase("/course")}>See all lessons</a>
        </div>

        <div class="roadmap-strip" style="margin: 26px 0 24px;">
          {tracks.map((track, index) => (
            <article class="roadmap-step">
              <span class="index">{index + 1}</span>
              <h3>{track.title}</h3>
              <p>{track.description}</p>
            </article>
          ))}
        </div>

        <div class="cards-3">
          <article class="feature-card">
            <span class="card-kicker">Latest lessons</span>
            <div class="card-stack">
              {featuredLessons.map((lesson) => (
                <article class="card">
                  <span class="card-kicker">{lesson.data.track}</span>
                  <h3>{lesson.data.title}</h3>
                  <p>{lesson.data.summary}</p>
                  <div class="actions">
                    <a class="button-secondary" href={withBase(`/course/${lesson.slug}/`)}>Open lesson</a>
                  </div>
                </article>
              ))}
            </div>
          </article>

          <article class="feature-card">
            <span class="card-kicker">Core notes</span>
            <div class="card-stack">
              {featuredNotes.map((note) => (
                <article class="card">
                  <h3>{note.data.title}</h3>
                  <p>{note.data.summary}</p>
                  <div class="actions">
                    <a class="button-secondary" href={withBase(`/resources/${note.slug}/`)}>Open note</a>
                  </div>
                </article>
              ))}
            </div>
          </article>

          <article class="feature-card">
            <span class="card-kicker">Patch library</span>
            <div class="card-stack">
              {featuredPatches.map((patch) => (
                <article class="card">
                  <span class="card-kicker">{patch.data.track}</span>
                  <h3>{patch.data.title}</h3>
                  <p>{patch.data.summary}</p>
                  <div class="actions">
                    <a class="button-secondary" href={withBase(`/patches/${patch.slug}/`)}>Open patch</a>
                  </div>
                </article>
              ))}
            </div>
          </article>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
