---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { trackLabelMap } from "../../../data/tracks";
import { withBase } from "../../../lib/paths";

export async function getStaticPaths() {
  const patches = await getCollection("patches");

  return patches.map((patch) => ({
    params: { slug: patch.slug },
    props: { patch }
  }));
}

const { patch } = Astro.props;
const { Content } = await render(patch);
const displayTrack = patch.data.track === "performances" ? "hybrid" : patch.data.track;
const siblingPatches = (await getCollection("patches"))
  .filter((entry) => entry.data.track === patch.data.track && entry.slug !== patch.slug)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout
  title={`${patch.data.title} | Modular Genesis | RU`}
  description={patch.data.summary}
  lang="ru"
  navItems={[
    { href: "/ru/", label: "Главная" },
    { href: "/ru/roadmap", label: "Roadmap" },
    { href: "/ru/course", label: "Course" },
    { href: "/ru/resources", label: "Resources" }
  ]}
  localeSwitch={{ href: `/patches/${patch.slug}/`, label: "EN" }}
>
  <div class="page-stack">
    <section class="band band-hero">
      <div class="band-shell">
        <div class="display-grid">
          <div>
            <div class="eyebrow">{trackLabelMap[displayTrack]}</div>
            <h1 class="display-title" style="max-width: 8ch; font-size: clamp(3.1rem, 7vw, 5.6rem);">
              {patch.data.title}
            </h1>
            <p class="lede">{patch.data.summary}</p>
            <div class="actions">
              <a class="button" href={withBase("/ru/patches")}>Назад к patches</a>
              <a class="button-secondary" href={withBase("/ru/course")}>Открыть course</a>
            </div>
          </div>

          <div class="hero-dashboard">
            <article class="feature-card">
              <span class="section-label">Patch metadata</span>
              <h3>{patch.data.filename}</h3>
              <ul class="metric-list">
                <li>
                  <strong>{patch.data.status}</strong>
                  текущий artifact status
                </li>
                <li>
                  <strong>{patch.data.track}</strong>
                  collection track
                </li>
                <li>
                  <strong>{patch.data.order}</strong>
                  текущий порядок внутри library
                </li>
                <li>
                  <strong>{patch.data.version ?? "v0.1"}</strong>
                  patch entry version
                </li>
              </ul>
            </article>

            <article class="feature-card">
              <span class="section-label">Repository path</span>
              <h3>Patch file location</h3>
              <p>
                Связанный patch artifact лежит в репозитории и позже может быть заменен реальным `VCV Rack` patch
                без изменения site route.
              </p>
              <div class="code-block">{`patches/${patch.data.track}/${patch.data.filename}`}</div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="band band-alt">
      <div class="band-shell">
        <div class="stack-grid">
          <article class="feature-card">
            <span class="card-kicker">Media state</span>
            <h3>Attached artifact media</h3>
            <ul class="feature-list">
              <li>
                <strong>Screenshot:</strong> {patch.data.image ? "attached" : "not attached yet"}
              </li>
              <li>
                <strong>Demo audio:</strong> {patch.data.audio ? "attached" : "not attached yet"}
              </li>
              <li>
                <strong>Duration:</strong> {patch.data.duration ?? "not specified"}
              </li>
            </ul>
          </article>

          {patch.data.image ? (
            <div class="media-frame">
              <img src={withBase(patch.data.image)} alt={`${patch.data.title} screenshot`} />
            </div>
          ) : (
            <article class="feature-card">
              <span class="card-kicker">Next artifact</span>
              <h3>Recommended first upload</h3>
              <p>Добавь один clean patch screenshot в `assets/images/patches/` и подключи его к этому entry.</p>
            </article>
          )}

          {patch.data.audio ? (
            <article class="feature-card">
              <span class="card-kicker">Demo audio</span>
              <h3>Patch preview</h3>
              <audio controls preload="none" style="width: 100%; margin-top: 8px;">
                <source src={withBase(patch.data.audio)} />
              </audio>
            </article>
          ) : (
            <article class="feature-card">
              <span class="card-kicker">Audio target</span>
              <h3>Recommended demo</h3>
              <p>Экспортируй короткий 20-60 second example и положи его в `assets/audio/patches/`.</p>
            </article>
          )}
        </div>
      </div>
    </section>

    <section class="band band-subtle">
      <div class="band-shell">
        <article class="feature-card prose-panel">
          <Content />
        </article>
      </div>
    </section>

    <section class="band band-deep">
      <div class="band-shell">
        <div class="stack-grid">
          <article class="feature-card">
            <span class="card-kicker">Same collection</span>
            <h3>More patch entries</h3>
            <ul class="feature-list">
              {siblingPatches.map((entry) => (
                <li>
                  <a href={withBase(`/ru/patches/${entry.slug}/`)}>{entry.data.title}</a>
                </li>
              ))}
            </ul>
          </article>

          <article class="feature-card">
            <span class="card-kicker">Navigation</span>
            <h3>Связать patch обратно с системой</h3>
            <p>Patch entries должны связывать repository artifacts, course pages и roadmap logic.</p>
            <div class="actions">
              <a class="button-secondary" href={withBase("/ru/roadmap")}>Открыть roadmap</a>
              <a class="button-secondary" href={withBase("/ru/resources")}>Читать notes</a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
