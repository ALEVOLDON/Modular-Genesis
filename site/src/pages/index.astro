---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { tracks } from "../data/tracks";

const lessons = (await getCollection("lessons")).sort((a, b) => {
  if (a.data.track === b.data.track) return a.data.order - b.data.order;
  return a.data.track.localeCompare(b.data.track);
});

const notes = (await getCollection("notes")).sort((a, b) => a.data.order - b.data.order);
const patches = (await getCollection("patches")).sort((a, b) => a.data.order - b.data.order);

const latestLessons = lessons.slice(0, 4);
const featuredNotes = notes.slice(0, 3);
const featuredPatches = patches.slice(0, 4);

const pillars = [
  {
    kicker: "System",
    title: "Hybrid audio architecture",
    text: "Ableton Live, VCV Rack, routing, recording, and visuals are treated as one connected system."
  },
  {
    kicker: "Course",
    title: "Structured learning path",
    text: "The project already has tracks, lessons, notes, and internal logic instead of loose tutorial fragments."
  },
  {
    kicker: "Library",
    title: "Patch-first repository design",
    text: "Patch entries, repository folders, and future real `.vcv` files already have a stable home."
  }
];
---

<BaseLayout
  title="Modular Genesis"
  description="Open modular synthesis, generative music, and audiovisual systems."
>
  <section class="hero">
    <div class="eyebrow">Public Draft v0.1</div>
    <div class="hero-copy">
      <h1>Open modular systems for sound, structure, and audiovisual practice.</h1>
      <p>
        Modular Genesis is an open documentation-first project around `VCV Rack`,
        `Ableton Live`, generative patch design, hybrid routing, and audiovisual systems.
        It already exists as a real repository and working website, not just a concept.
      </p>
      <div class="actions">
        <a class="button" href="/roadmap">View roadmap</a>
        <a class="button-secondary" href="/course">Open course outline</a>
        <a class="button-secondary" href="/resources">Read notes</a>
      </div>
    </div>

    <div class="panel-grid hero-grid">
      <div class="panel">
        <div class="section-head">
          <div>
            <h2>Core pipeline</h2>
            <p>The backbone that connects the current course, patch library, and future visual layer.</p>
          </div>
        </div>
        <div class="code-block">Ableton / MIDI
  ->
VCV Rack
  ->
Generative Patch
  ->
Audio Engine
  ->
Visual Engine
  ->
Performance</div>
      </div>

      <div class="panel">
        <h2>Current status</h2>
        <ul class="stat-list">
          <li>
            <span class="stat-value">{tracks.length}</span>
            learning tracks already structured
          </li>
          <li>
            <span class="stat-value">{lessons.length}</span>
            lesson pages already published
          </li>
          <li>
            <span class="stat-value">{notes.length}</span>
            reference notes available on-site
          </li>
          <li>
            <span class="stat-value">{patches.length}</span>
            patch entries prepared for real `.vcv` files
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <h2>Main pillars</h2>
        <p>The repository is being organized around three durable outputs.</p>
      </div>
    </div>
    <div class="cards-3">
      {pillars.map((pillar) => (
        <article class="card">
          <span class="card-kicker">{pillar.kicker}</span>
          <h3>{pillar.title}</h3>
          <p>{pillar.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <h2>System map</h2>
        <p>A native diagram extracted from the project structure and redrawn to match the site.</p>
      </div>
      <a class="button-secondary" href="/roadmap">Open roadmap</a>
    </div>
    <div class="media-frame">
      <img src="/diagrams/tool-ecosystem.svg" alt="Tool ecosystem diagram for Modular Genesis." />
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <h2>Latest lessons</h2>
        <p>The course already has live content across multiple tracks.</p>
      </div>
      <a class="button-secondary" href="/course">All lessons</a>
    </div>
    <div class="cards-2">
      {latestLessons.map((lesson) => (
        <article class="card">
          <span class="card-kicker">{lesson.data.track}</span>
          <h3>{lesson.data.title}</h3>
          <p>{lesson.data.summary}</p>
          <div class="actions">
            <a class="button-secondary" href={`/course/${lesson.slug}/`}>Open lesson</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="cards-2">
      <div>
        <div class="section-head">
          <div>
            <h2>Core notes</h2>
            <p>Reference material that explains the system behind the lessons.</p>
          </div>
        </div>
        <div class="cards-1">
          {featuredNotes.map((note) => (
            <article class="card">
              <span class="card-kicker">Note</span>
              <h3>{note.data.title}</h3>
              <p>{note.data.summary}</p>
              <div class="actions">
                <a class="button-secondary" href={`/resources/${note.slug}/`}>Open note</a>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div>
        <div class="section-head">
          <div>
            <h2>Patch library</h2>
            <p>Structured entries are already in place, ready for real patch files.</p>
          </div>
        </div>
        <div class="cards-1">
          {featuredPatches.map((patch) => (
            <article class="card">
              <span class="card-kicker">{patch.data.track}</span>
              <h3>{patch.data.title}</h3>
              <p>{patch.data.summary}</p>
              <div class="actions">
                <a class="button-secondary" href={`/patches/${patch.slug}/`}>Open patch</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
