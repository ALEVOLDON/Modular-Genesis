---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { tracks } from "../../data/tracks";
import { withBase } from "../../lib/paths";

const lessons = (await getCollection("ru-lessons")).sort((a, b) => {
  if (a.data.track === b.data.track) return a.data.order - b.data.order;
  return a.data.track.localeCompare(b.data.track);
});

const notes = (await getCollection("ru-notes")).sort((a, b) => a.data.order - b.data.order);
const patches = (await getCollection("ru-patches")).sort((a, b) => a.data.order - b.data.order);

const latestLessons = lessons.slice(0, 4);
const featuredNotes = notes.slice(0, 3);
const featuredPatches = patches.slice(0, 3);

const pillars = [
  {
    kicker: "Система",
    title: "Гибридная аудиоархитектура",
    text: "Ableton Live, VCV Rack, маршрутизация, запись и визуальный слой собраны как единая рабочая система.",
    points: ["модульный движок и DAW-слой", "маршрутизация как часть композиции", "визуальный вывод как продолжение звука"]
  },
  {
    kicker: "Курс",
    title: "Структурированный путь обучения",
    text: "В проекте уже есть треки, уроки, заметки и внутренняя логика вместо набора разрозненных туториалов.",
    points: ["от foundations до audiovisual", "модель lesson + note + patch", "roadmap как каркас курса"]
  },
  {
    kicker: "Репозиторий",
    title: "Patch-first структура",
    text: "У patch entries, папок репозитория и будущих `.vcv` файлов уже есть понятное и стабильное место.",
    points: ["публичная структура репозитория", "patch references на страницах", "готово к реальным артефактам"]
  }
];

const toolCards = [
  {
    title: "VCV Rack",
    text: "Главная модульная среда для синтеза, секвенсинга, вероятности и работы с сигналом."
  },
  {
    title: "Ableton Live",
    text: "Аранжировка, маршрутизация, запись, performance-контроль и опорный слой гибридного workflow."
  },
  {
    title: "Visual Layer",
    text: "Three.js, Blender и будущие real-time visual systems, связанные с поведением звука."
  },
  {
    title: "Repository",
    text: "Документация, патчи, диаграммы и уроки, собранные как единая открытая система знаний."
  }
];
---

<BaseLayout
  title="Modular Genesis | Русская версия"
  description="Русскоязычная стартовая страница проекта Modular Genesis."
  lang="ru"
  navItems={[
    { href: "/ru/", label: "Главная" },
    { href: "/ru/roadmap", label: "План" },
    { href: "/ru/course", label: "Курс" },
    { href: "/ru/resources", label: "Материалы" }
  ]}
  localeSwitch={{ href: "/", label: "EN" }}
>
  <div class="page-stack">
    <section class="band band-hero">
      <div class="band-shell">
        <div class="display-grid">
          <div>
            <div class="eyebrow">Русская версия v0.1</div>
            <h1 class="display-title">
              Открытая <span class="accent">generative</span> система для modular sound и audiovisual practice.
            </h1>
            <p class="lede">
              Modular Genesis - это documentation-first проект про `VCV Rack`, `Ableton Live`,
              генеративный patch design, гибридную маршрутизацию и будущие audiovisual systems.
              Русская версия нужна как понятная точка входа без разрыва с уже собранной английской структурой.
            </p>
            <div class="actions">
              <a class="button" href={withBase("/ru/roadmap")}>Открыть roadmap</a>
              <a class="button-secondary" href={withBase("/ru/course")}>Смотреть lessons</a>
              <a class="button-secondary" href={withBase("/ru/resources")}>Читать notes</a>
            </div>
          </div>

          <div class="hero-dashboard">
            <article class="feature-card">
              <span class="section-label">Основной pipeline</span>
              <h3>От control logic к audio и visual output</h3>
              <p>
                Сайт, lessons, notes и patch entries уже строятся вокруг одного backbone:
                controller input, modular generation, audio capture и будущего visual synthesis.
              </p>
              <div class="code-block">Ableton / MIDI
  ->
VCV Rack
  ->
Generative Patch
  ->
Audio Engine
  ->
Visual Engine
  ->
Performance</div>
            </article>

            <div class="hero-dashboard-grid">
              <article class="mini-card">
                <span class="mini-stat">{tracks.length}</span>
                <h4>Треков уже собрано</h4>
                <p>Foundations, sequencing, generative, hybrid и audiovisual уже оформлены как рабочий каркас.</p>
              </article>
              <article class="mini-card">
                <span class="mini-stat">{lessons.length}</span>
                <h4>Уроков опубликовано</h4>
                <p>На сайте уже есть реальные lesson pages, а не просто syllabus-заглушка.</p>
              </article>
              <article class="mini-card">
                <span class="mini-stat">{notes.length}</span>
                <h4>Заметок опубликовано</h4>
                <p>Опорные заметки объясняют routing, patch logic и общее направление проекта.</p>
              </article>
              <article class="mini-card">
                <span class="mini-stat">{patches.length}</span>
                <h4>Patch entries готовы</h4>
                <p>Структура уже готова под реальные `.vcv` артефакты без перестройки сайта.</p>
              </article>
            </div>

            <article class="feature-card">
              <span class="section-label">Что уже работает</span>
              <h3>Не только идея, но уже собранный фундамент</h3>
              <ul class="feature-list">
                <li><strong>Roadmap:</strong> поэтапная структура от signal flow до audiovisual systems.</li>
                <li><strong>Course:</strong> lessons уже сгруппированы по трекам и маршрутам.</li>
                <li><strong>Resources:</strong> concept notes и system diagrams уже опубликованы.</li>
              </ul>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="band band-deep">
      <div class="band-shell">
        <div class="section-copy">
          <span class="section-label">Экосистема</span>
          <h2>Инструменты разделены по роли, но спроектированы как единый организм.</h2>
          <p>
            Проект не делит synthesis, arrangement и visuals на отдельные дисциплины.
            Он собирает их как связанные слои одной системы.
          </p>
        </div>
        <div class="stack-grid-4" style="margin-top: 26px;">
          {toolCards.map((tool) => (
            <article class="feature-card">
              <span class="card-kicker">Инструмент</span>
              <h3>{tool.title}</h3>
              <p>{tool.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="band band-alt">
      <div class="band-shell">
        <div class="split-hero">
          <div class="feature-card">
            <span class="section-label">Почему modular</span>
            <h2>Это не просто sound design workflow, а среда для исследования.</h2>
            <p>
              Модульные системы соединяют композицию, логику, импровизацию и инженерию.
              Поэтому они подходят для живых систем, а не только для статичных пресетов.
            </p>
            <ul class="feature-list">
              <li><strong>Routing как композиция:</strong> сам signal path становится частью формы.</li>
              <li><strong>Generative logic:</strong> clocks, probability, mutation и feedback создают evolving behavior.</li>
              <li><strong>Audiovisual expansion:</strong> звуковые события позже могут управлять geometry, motion и scenes.</li>
            </ul>
          </div>

          <div class="media-frame">
            <img src={withBase("/diagrams/tool-ecosystem.svg")} alt="Диаграмма экосистемы инструментов Modular Genesis." />
          </div>
        </div>
      </div>
    </section>

    <section class="band band-subtle">
      <div class="band-shell">
        <div class="section-copy">
          <span class="section-label">Архитектура</span>
          <h2>Три устойчивых слоя уже собраны.</h2>
          <p>
            Текущая публичная версия - это еще не завершенный контент, а стабильный проектный каркас:
            архитектура системы, архитектура обучения и архитектура репозитория.
          </p>
        </div>
        <div class="stack-grid" style="margin-top: 26px;">
          {pillars.map((pillar) => (
            <article class="feature-card">
              <span class="card-kicker">{pillar.kicker}</span>
              <h3>{pillar.title}</h3>
              <p>{pillar.text}</p>
              <ul class="feature-list">
                {pillar.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="band band-deep">
      <div class="band-shell">
        <div class="section-head">
          <div class="section-copy">
            <span class="section-label">Живой контент</span>
            <h2>На сайте уже есть материал, а не просто пустой фасад.</h2>
            <p>Lessons, notes и patch entries разведены по понятным колонкам, чтобы каждый слой читался отдельно.</p>
          </div>
          <a class="button-secondary" href={withBase("/ru/course")}>Все lessons</a>
        </div>

        <div class="content-grid">
          <div class="content-column">
            <article class="feature-card">
              <span class="card-kicker">Последние уроки</span>
              <div class="card-stack">
                {latestLessons.map((lesson) => (
                  <article class="card">
                    <span class="card-kicker">{lesson.data.track}</span>
                    <h3>{lesson.data.title}</h3>
                    <p>{lesson.data.summary}</p>
                    <div class="actions">
                      <a class="button-secondary" href={withBase(`/ru/course/${lesson.slug}/`)}>Открыть lesson</a>
                    </div>
                  </article>
                ))}
              </div>
            </article>

            <article class="feature-card">
              <span class="card-kicker">Логика треков</span>
              <h3>Как растет учебная система</h3>
              <p>
                Текущий контент уже идет по стабильной последовательности: от базового сигнала к hybrid и audiovisual output.
              </p>
              <ul class="feature-list">
                {tracks.map((track, index) => (
                  <li>
                    <strong>Этап {index + 1}:</strong> {track.title} - {track.description}
                  </li>
                ))}
              </ul>
              <div class="actions">
                <a class="button-secondary" href={withBase("/ru/roadmap")}>Открыть полный roadmap</a>
              </div>
            </article>
          </div>

          <div class="content-column">
            <article class="feature-card">
              <span class="card-kicker">Базовые заметки</span>
              <div class="card-stack">
                {featuredNotes.map((note) => (
                  <article class="card">
                    <h3>{note.data.title}</h3>
                    <p>{note.data.summary}</p>
                    <div class="actions">
                      <a class="button-secondary" href={withBase(`/ru/resources/${note.slug}/`)}>Открыть note</a>
                    </div>
                  </article>
                ))}
              </div>
            </article>

            <article class="feature-card">
              <span class="card-kicker">Patch library</span>
              <div class="card-stack">
                {featuredPatches.map((patch) => (
                  <article class="card">
                    <span class="card-kicker">{patch.data.track}</span>
                    <h3>{patch.data.title}</h3>
                    <p>{patch.data.summary}</p>
                    <div class="actions">
                      <a class="button-secondary" href={withBase(`/ru/patches/${patch.slug}/`)}>Открыть patch</a>
                    </div>
                  </article>
                ))}
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
