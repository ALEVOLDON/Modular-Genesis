---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { trackLabelMap } from "../../../data/tracks";
import { withBase } from "../../../lib/paths";

export async function getStaticPaths() {
  const patches = await getCollection("ru-patches");

  return patches.map((patch) => ({
    params: { slug: patch.slug },
    props: { patch }
  }));
}

const { patch } = Astro.props;
const { Content } = await render(patch);
const displayTrack = patch.data.track === "performances" ? "hybrid" : patch.data.track;

const collectionCopy = {
  foundations: { title: "Foundations" },
  sequencing: { title: "Sequencing" },
  generative: { title: "Generative" },
  performances: { title: "Performances" },
  hybrid: { title: "Hybrid" }
};
const translatedTrackTitle = collectionCopy[displayTrack as keyof typeof collectionCopy]?.title || "Foundations";

const siblingPatches = (await getCollection("ru-patches"))
  .filter((entry) => entry.data.track === patch.data.track && entry.slug !== patch.slug)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout
  title={`${patch.data.title} | Modular Genesis | RU`}
  description={patch.data.summary}
  lang="ru"
  navItems={[
    { href: "/ru/", label: "Главная" },
    { href: "/ru/roadmap", label: "План" },
    { href: "/ru/course", label: "Курс" },
    { href: "/ru/resources", label: "Материалы" }
  ]}
  localeSwitch={{ href: `/patches/${patch.slug}/`, label: "EN" }}
>
  <div class="page-stack">
    <section class="band band-hero">
      <div class="band-shell">
        <div class="display-grid">
          <div>
            <div class="eyebrow">{translatedTrackTitle}</div>
            <h1 class="display-title" style="max-width: 8ch; font-size: clamp(3.1rem, 7vw, 5.6rem);">
              {patch.data.title}
            </h1>
            <p class="lede">{patch.data.summary}</p>
            <div class="actions">
              <a class="button" href={withBase("/ru/patches")}>Назад к патчам</a>
              <a class="button-secondary" href={withBase("/ru/course")}>Открыть курс</a>
            </div>
          </div>

          <div class="hero-dashboard">
            <article class="feature-card">
              <span class="section-label">Метаданные патча</span>
              <h3>{patch.data.filename}</h3>
              <ul class="metric-list">
                <li>
                  <strong>{patch.data.status}</strong>
                  текущий статус артефакта
                </li>
                <li>
                  <strong>{patch.data.track}</strong>
                  трек коллекции
                </li>
                <li>
                  <strong>{patch.data.order}</strong>
                  текущий порядок внутри библиотеки
                </li>
                <li>
                  <strong>{patch.data.version ?? "v0.1"}</strong>
                  версия patch entry
                </li>
              </ul>
            </article>

            <article class="feature-card">
              <span class="section-label">Путь в репозитории</span>
              <h3>Расположение patch file</h3>
              <p>
                Связанный patch artifact лежит в репозитории и позже может быть заменен реальным `VCV Rack` patch
                без изменения site route.
              </p>
              <div class="code-block">{`patches/${patch.data.track}/${patch.data.filename}`}</div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="band band-alt">
      <div class="band-shell">
        <div class="stack-grid">
          <article class="feature-card">
            <span class="card-kicker">Состояние медиа</span>
            <h3>Подключенные материалы</h3>
            <ul class="feature-list">
              <li>
                <strong>Скриншот:</strong> {patch.data.image ? "подключен" : "еще не добавлен"}
              </li>
              <li>
                <strong>Демо-аудио:</strong> {patch.data.audio ? "подключено" : "еще не добавлено"}
              </li>
              <li>
                <strong>Длительность:</strong> {patch.data.duration ?? "не указана"}
              </li>
            </ul>
          </article>

          {patch.data.image ? (
            <div class="media-frame">
              <img src={withBase(patch.data.image)} alt={`${patch.data.title} screenshot`} />
            </div>
          ) : (
            <article class="feature-card">
              <span class="card-kicker">Следующий артефакт</span>
              <h3>Рекомендуемый первый файл</h3>
              <p>Добавь один clean patch screenshot в `assets/images/patches/` и подключи его к этому entry.</p>
            </article>
          )}

          {patch.data.audio ? (
            <article class="feature-card">
              <span class="card-kicker">Демо-аудио</span>
              <h3>Предпросмотр патча</h3>
              <audio controls preload="none" style="width: 100%; margin-top: 8px;">
                <source src={withBase(patch.data.audio)} />
              </audio>
            </article>
          ) : (
            <article class="feature-card">
              <span class="card-kicker">Аудиоцель</span>
              <h3>Рекомендуемое демо</h3>
              <p>Экспортируй короткий 20-60 second example и положи его в `assets/audio/patches/`.</p>
            </article>
          )}
        </div>
      </div>
    </section>

    <section class="band band-subtle">
      <div class="band-shell">
        <article class="feature-card prose-panel">
          <Content />
        </article>
      </div>
    </section>

    <section class="band band-deep">
      <div class="band-shell">
        <div class="stack-grid">
          <article class="feature-card">
            <span class="card-kicker">Та же коллекция</span>
            <h3>Другие patch entries</h3>
            <ul class="feature-list">
              {siblingPatches.map((entry) => (
                <li>
                  <a href={withBase(`/ru/patches/${entry.slug}/`)}>{entry.data.title}</a>
                </li>
              ))}
            </ul>
          </article>

          <article class="feature-card">
            <span class="card-kicker">Навигация</span>
            <h3>Связать patch обратно с системой</h3>
            <p>Patch entries должны связывать repository artifacts, course pages и roadmap logic.</p>
            <div class="actions">
              <a class="button-secondary" href={withBase("/ru/roadmap")}>Открыть roadmap</a>
              <a class="button-secondary" href={withBase("/ru/resources")}>Читать заметки</a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
