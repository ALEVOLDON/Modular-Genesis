---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { withBase } from "../../../lib/paths";

export async function getStaticPaths() {
  const notes = await getCollection("ru-notes");

  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note }
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const otherNotes = (await getCollection("ru-notes"))
  .filter((entry) => entry.slug !== note.slug)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout
  title={`${note.data.title} | Modular Genesis | RU`}
  description={note.data.summary}
  lang="ru"
  navItems={[
    { href: "/ru/", label: "Главная" },
    { href: "/ru/roadmap", label: "План" },
    { href: "/ru/course", label: "Курс" },
    { href: "/ru/resources", label: "Материалы" }
  ]}
  localeSwitch={{ href: `/resources/${note.slug}/`, label: "EN" }}
>
  <div class="page-stack">
    <section class="band band-hero">
      <div class="band-shell">
        <div class="display-grid">
          <div>
            <div class="eyebrow">Опорная заметка</div>
            <h1 class="display-title" style="max-width: 8ch; font-size: clamp(3.1rem, 7vw, 5.4rem);">
              {note.data.title}
            </h1>
            <p class="lede">{note.data.summary}</p>
            <div class="actions">
              <a class="button" href={withBase("/ru/resources")}>Назад к материалам</a>
              <a class="button-secondary" href={withBase("/ru/roadmap")}>Открыть roadmap</a>
            </div>
          </div>

          <div class="hero-dashboard">
            <article class="feature-card">
              <span class="section-label">Роль заметки</span>
              <h3>Концептуальный слой для публичной системы</h3>
              <p>Такие заметки объясняют устойчивую логику за уроками, патчами и дальнейшим ростом сайта.</p>
              <ul class="feature-list">
                <li>контекст рабочего процесса и маршрутизации</li>
                <li>системная архитектура и направление проекта</li>
                <li>поддержка для будущих уроков и артефактов</li>
              </ul>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="band band-subtle">
      <div class="band-shell">
        <article class="feature-card prose-panel">
          <Content />
        </article>
      </div>
    </section>

    <section class="band band-deep">
      <div class="band-shell">
        <div class="stack-grid">
          <article class="feature-card">
            <span class="card-kicker">Другие заметки</span>
            <h3>Связанные материалы</h3>
            <ul class="feature-list">
              {otherNotes.map((entry) => (
                <li>
                  <a href={withBase(`/ru/resources/${entry.slug}/`)}>{entry.data.title}</a>
                </li>
              ))}
            </ul>
          </article>

          <article class="feature-card">
            <span class="card-kicker">Навигация</span>
            <h3>Продолжить движение по системе</h3>
            <p>Справочные материалы должны возвращать тебя в roadmap, к урокам и в библиотеку патчей.</p>
            <div class="actions">
              <a class="button-secondary" href={withBase("/ru/course")}>Открыть курс</a>
              <a class="button-secondary" href={withBase("/ru/patches")}>Открыть патчи</a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
